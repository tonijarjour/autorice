#!/bin/sh

while read -r file
do
    case "$1" in
        "C-c")
                xclip -se c -t image/png "$file" ;;
        "C-w")
                feh --bg-fill --no-fehbg "$file" ;;
        "C-D")
                rm "$file" ;;
        *)
                echo "Undefined Key"
                exit 1
                ;;
    esac
done
